subscription_id = " "

default_location = "centralindia"
default_rg_tags = {
  environment = "prod"
  managed_by  = "terraform"
}

# Copy one block below per resource group you need.
# Both fields are optional — omit and it falls back to
# default_location / default_rg_tags above.

resource_groups = {
  "rg-prod-app" = {
    tags = { role = "app" }
  }

  "rg-prod-data" = {
    location = "eastus"
    tags     = { role = "data" }
  }

  "rg-prod-network" = {
    # uses every default as-is
  }
}
